{
    "name": "Smart Aqua Engineering Lab",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspace",

    // Funcionalidades: Instala extensões úteis automaticamente no VS Code do aluno
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",           // Suporte a Python
                "ms-python.debugpy",          // Debugger
                "mtxr.sqltools",              // Cliente SQL Leve para ver o Timescale
                "mtxr.sqltools-driver-pg"    // Driver Postgres para o SQLTools
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    },

    "forwardPorts": [3000, 4000],
    "portsAttributes": {
        "3000": {
        "label": "MQTT Explorer Server",
        "onAutoForward": "notify"
        },
        "4000": {
        "label": "MQTT Explorer Web UI",
        "onAutoForward": "notify"
        }
    },

    // Automação: Roda assim que o container é criado.
    // O aluno não precisa lembrar de dar pip install.
    "postCreateCommand": "pip install --user -r curso/requirements.txt",

    // Usuário remoto (o container python da Microsoft já usa 'vscode' ou 'root')
    "remoteUser": "vscode"
}